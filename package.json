{
  "name": "vincent-stock-v2",
  "version": "0.1.0",
  "private": true,
  "description": "Vincent Stock Intelligence System — 個人金融情報系統",
  "scripts": {
    "dev": "pnpm --filter vsis-frontend dev",
    "build": "pnpm --filter vsis-frontend build",
    "backend": "uvicorn backend.main:app --reload",
    "test:backend": "pytest backend/tests -v",
    "install:backend": "pip install -r backend/requirements.txt",
    "install:frontend": "cd frontend && pnpm install"
  },
  "workspaces": ["frontend"],
  "engines": {
    "node": ">=20"
  }
}
