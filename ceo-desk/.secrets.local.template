# ceo-desk/.secrets.local — 本機機敏值存放(gitignored)
#
# 使用流程:
#   1. CEO 在 Supabase Dashboard 重設 DB password
#      Settings → Database → Reset database password
#   2. 拷貝新 password 進 ceo-desk/.secrets.local(本檔案的 real 副本)
#   3. 跑 python scripts/t3a_apply_password_rotation.py
#      → 自動同步進 .env / .env.local / Zeabur env 並驗證連線
#
# 此檔案是 template,請複製為 ceo-desk/.secrets.local 後填入真實值。
# .secrets.local 已 gitignored,絕對不會被 commit。

# Supabase 主資料庫 password(只在本機本檔案保存)
SUPABASE_DB_PASSWORD=

# 旋轉時間紀錄(供追蹤,純文字)
SUPABASE_DB_PASSWORD_ROTATED_AT=

# Supabase Personal Access Token(若 Vincent 從 https://supabase.com/dashboard/account/tokens 拿到 sbp_*)
# 設了之後 Claude Code 可以透過 Management API 自動 reset password、apply migration 等
SUPABASE_ACCESS_TOKEN=

# Zeabur API token(若有 — 設了之後可自動更新 backend env)
ZEABUR_TOKEN=
