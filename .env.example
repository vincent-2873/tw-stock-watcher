# ============================================
# Vincent Stock Intelligence System
# 環境變數設定範本
# ============================================
# 使用方法:
# 1. cp .env.example .env
# 2. 把下面每一行的值改成你的實際 API Key
# 3. 永遠不要 commit .env 到 GitHub
# ============================================

# =========================
# Supabase (資料庫)
# =========================
# 申請:https://supabase.com
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_KEY=eyJhbGci...

# =========================
# FinMind (台股資料)
# =========================
# 申請:https://finmindtrade.com
FINMIND_TOKEN=eyJhbGci...

# =========================
# FMP (美股資料)
# =========================
# 申請:https://financialmodelingprep.com/developer
FMP_API_KEY=xxxxx

# =========================
# NewsAPI (新聞)
# =========================
# 申請:https://newsapi.org
NEWS_API_KEY=xxxxx

# =========================
# Anthropic Claude API (AI 分析)
# =========================
# 申請:https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# =========================
# LINE Messaging API (推播)
# =========================
# 申請:https://developers.line.biz/console
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxx
LINE_CHANNEL_SECRET=xxxxx
LINE_USER_ID=Uxxxxxxxxxxxxx

# =========================
# Gmail (備援通知)
# =========================
# App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# =========================
# 系統設定
# =========================
# 環境:development / production
NODE_ENV=development
PYTHON_ENV=development

# 時區(台灣)
TZ=Asia/Taipei

# 日誌級別
LOG_LEVEL=INFO

# =========================
# 前端設定(Next.js)
# =========================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
NEXT_PUBLIC_API_URL=http://localhost:8000

# =========================
# 使用者設定
# =========================
USER_ID=vincent
USER_NAME=Vincent
USER_EMAIL=your@email.com

# =========================
# 進階設定(可選)
# =========================
# 啟用除錯模式
DEBUG=false

# AI 服務降級閾值(幾次失敗後切換到備援)
AI_FAILURE_THRESHOLD=3

# 警報冷卻時間(秒)
ALERT_COOLDOWN_SECONDS=300

# 單日警報上限
MAX_ALERTS_PER_DAY=30

# 快取 TTL(秒)
CACHE_TTL_STOCK_INFO=3600
CACHE_TTL_NEWS=1800
CACHE_TTL_ANALYSIS=600

# =========================
# GitHub PAT(給 cron-job.org 用於精準觸發 workflow)
# =========================
# 申請:https://github.com/settings/tokens (classic)
# 權限勾選:workflow
# 詳見 specs/10_zero_lag_scheduling.md
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=vincent-stock-system

# =========================
# 排程精準度監控
# =========================
# 容許的最大 drift(毫秒),超過會寫入 system_health
MAX_SCHEDULE_DRIFT_MS=1000
# 連續幾次 drift 超標就通知 Vincent
DRIFT_ALERT_CONSECUTIVE=3

# =========================
# X (Twitter) API - VIP 人物即時追蹤
# =========================
# 申請:https://developer.x.com
# 方案:Pay-Per-Use(預估 $32/月)
# 詳見 specs/12_social_intelligence.md
X_API_BEARER_TOKEN=your_x_bearer_token_here
X_API_KEY=your_x_api_key_here
X_API_KEY_SECRET=your_x_api_secret_here

# 月費上限(超過會停止 X API 呼叫)
X_API_MAX_MONTHLY_USD=50

# =========================
# 其他社群平台(免費)
# =========================
# Truth Social 用 truthbrush(免費,不需 token)
# PTT 直接爬(免費)
# Google Trends 用 pytrends(免費)
