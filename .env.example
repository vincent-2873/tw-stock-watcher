# ============================================================
# 複製這份為 .env.local（.env.local 已加入 .gitignore，不會外洩）
# ============================================================

# === Supabase（前往 supabase.com 建 project 後填入）===
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === AI（新聞情緒、個股健檢、推薦） ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === 台股資料源（免費） ===
# FinMind：https://finmindtrade.com/analysis/#/data/api（註冊免費 500req/hr）
FINMIND_TOKEN=
# Fugle：https://developer.fugle.tw/（富果免費即時 API，1000 req/day）
FUGLE_API_KEY=
# TWSE 不需要 key，直接打 openapi

# === 新聞（免費/低成本） ===
# NewsAPI：https://newsapi.org/（100 req/day 免費）
NEWS_API_KEY=

# === 推播（選配） ===
LINE_NOTIFY_TOKEN=
DISCORD_WEBHOOK=

# === 部署 ===
ZEABUR_TOKEN=
GITHUB_TOKEN=
